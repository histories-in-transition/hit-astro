---
import PageLayout from "../layouts/page-layout.astro";
import msitems from "../content/data/ms_items.json";
import Button from "../components/button.astro";
import { Icon } from "astro-icon/components";
import NavLink from "../components/nav-link.astro";
const msItems = Object.values(msitems);
---

<PageLayout>
  <div class="mx-auto p-4 lg:w-4/5">
    <div>
      <div class="flex justify-between align-middle mb-2">
        <h2 class="text-2xl font-semibold text-brandRed py-2">Werke</h2>
        <div class="flex gap-3">
          <button
            class="border border-brandRed rounded-md py-2 px-4 bg-brandRed text-brandRose hover:bg-brandRose hover:text-brandRed transition"
            id="download-csv"
            >CSV <Icon
              aria-hidden="true"
              name="lucide:download"
              class="inline-flex"
            /></button
          >
          <button
            class="border border-brandRed rounded-md py-2 px-4 bg-brandRed text-brandRose hover:bg-brandRose hover:text-brandRed transition"
            id="download-json"
            >json <Icon
              aria-hidden="true"
              name="lucide:download"
              class="inline-flex"
            /></button
          >
          <button
            class="border border-brandRed rounded-md py-2 px-4 bg-brandRed text-brandRose hover:bg-brandRose hover:text-brandRed transition"
            id="download-html"
            >html <Icon
              aria-hidden="true"
              name="lucide:download"
              class="inline-flex"
            /></button
          >
        </div>
      </div>
    </div>
    <div class="overflow-y-auto max-h-[1000px]">
      <div id="tabulator-table"></div>
    </div>
  </div>
  <script>
    import { TabulatorFull as Tabulator } from "tabulator-tables";
    import "tabulator-tables/dist/css/tabulator.min.css";
    import data from "../content/data/works.json";
    import {
      mutateM2mField,
      mutateNestedM2mField,
    } from "../lib/tabulator-utils.js";

    var tabledata = [...Object.values(data)];

    var table = new Tabulator("#tabulator-table", {
      headerFilterLiveFilterDelay: 600,
      height: 800,
      data: tabledata,
      layout: "fitColumns",
      responsiveLayout: "collapse",
      columns: [
        { title: "Titel", field: "view_label", headerFilter: "input" },
        {
          title: "Autor",
          field: "author",
          editor: "input",
          mutator: mutateM2mField,
          /*  mutator uses function mutate many to many to read the array - helpers function in the lib forlder. */
          mutatorParams: { labelField: "name" },
          /* It has a parameter which specifies the exact object name in the json to be used - for each json table specific so we have it extracted as param to be able to use the function for all tables. Then in each table - set the specific mutatorParam labelField */
          headerFilter: "input",
        },

        {
          title: "Haupgenre",
          field: "genre",
          mutator: mutateNestedM2mField,
          mutatorParams: { labelField: "main_genre" },
          headerFilter: "input",
        },

        /*   {
          title: "Nebengenre",
          field: "genre",
          mutator: mutateM2mField,
          mutatorParams: { labelField: "genre" },
          headerFilter: "input",
        }, */
        {
          title: "Überlieferung",
        },
      ],
    });

    //trigger download of data.csv file
    document
      .getElementById("download-csv")!
      .addEventListener("click", function () {
        table.download("csv", "data.csv");
      });

    //trigger download of data.json file
    document
      .getElementById("download-json")!
      .addEventListener("click", function () {
        table.download("json", "data.json");
      });

    //trigger download of data.html file
    document
      .getElementById("download-html")!
      .addEventListener("click", function () {
        table.download("html", "data.html", { style: true });
      });

    // event listeners set:
    // href to the work detail view page
    table.on("rowClick", function (e, row) {
      var data = row.getData();
      var url = `works/${data["hit_id"]}`;
      window.open(url, "_self");
    });
  </script>
</PageLayout>
